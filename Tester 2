        "ISTJ": { advice: "The Logistician is the ultimate 'Anchor.' Your AM code is the mechanical verification of your duty.", action: "Optimizing the 'Order' is your gift. Create a template today that removes friction for others." },
        "ESTJ": { advice: "The Executive needs the 'Restriction' (B) of a hierarchy. Use the AM to solidify your rank.", action: "Audit your current department. Where is the noise? Apply the 'Iron Vanguard' logic to silence it." },
        "ISFJ": { advice: "The Defender seeks World-type stability. Your AM code is your shield for the people you protect.", action: "Build a 'Stability Guide' for your family or team to handle the next chaotic event." },
        "ESFJ": { advice: "The Consul lives for the group. Use your AM 'Acquisition' style to learn the needs of your 'World'.", action: "Host a strategic review where the only goal is to define the team's 'Mantra'." },
        "ISTP": { advice: "The Virtuoso is a natural Sniper. Your AM code must allow for high-stakes, short-burst execution.", action: "Find the most technical 'Problem' in the room and solve it alone. Don't explain the logic." },
        "ESTP": { advice: "The Entrepreneur thrives on the 'High'. Use your AM 'Restriction' to stop you from drifting.", action: "Take a high-stakes risk today where the win is purely personal (Self-type)." },
        "ISFP": { advice: "The Adventurer needs Freedom (A). Your AM code is the canvas for your personal mastery.", action: "Produce one piece of 'Work as Art' today. Ignore the efficiency metrics." },
        "ESFP": { advice: "The Entertainer treat the 'Order' like a stage. Use your AM engine to own the spotlight.", action: "Perform your results. Present a complex strategy with the flair of a Fluid Director." }
    };

    let step = 0;
    let results = { System: [], Environment: [], Acquisition: [], Motivation: [] };
    let isCalibrating = false;
    let originalCode = "";

    function initQuiz() {
        document.getElementById('intro').classList.remove('active');
        document.getElementById('quiz').classList.add('active');
        isCalibrating = false;
        step = 0;
        results = { System: [], Environment: [], Acquisition: [], Motivation: [] };
        loadQuestion();
    }

    function startCalibration() {
        isCalibrating = true;
        step = 0;
        results = { System: [], Environment: [], Acquisition: [], Motivation: [] };
        document.getElementById('results').classList.remove('active');
        document.getElementById('quiz').classList.add('active');
        loadCalibrationQuestion();
    }

    function loadQuestion() {
        const q = questions[step];
        document.getElementById('domain').innerText = `Domain: ${q.d}`;
        document.getElementById('question').innerText = q.q;
        document.getElementById('optA').innerText = q.a;
        document.getElementById('optB').innerText = q.b;
        document.getElementById('progress-fill').style.width = `${(step / questions.length) * 100}%`;
    }

    function loadCalibrationQuestion() {
        const q = calibrationQuestions[step];
        document.getElementById('domain').innerText = `Calibration: ${q.d}`;
        document.getElementById('question').innerText = q.q;
        document.getElementById('optA').innerText = q.a;
        document.getElementById('optB').innerText = q.b;
        document.getElementById('progress-fill').style.width = `${(step / calibrationQuestions.length) * 100}%`;
    }

    function answer(val) {
        const qList = isCalibrating ? calibrationQuestions : questions;
        results[qList[step].d].push(val);
        step++;
        
        if (step < qList.length) {
            isCalibrating ? loadCalibrationQuestion() : loadQuestion();
        } else {
            finalize();
        }
    }

    function finalize() {
        const getMode = (arr) => {
            const counts = arr.reduce((acc, v) => (acc[v] = (acc[v] || 0) + 1, acc), {});
            return counts['A'] > counts['B'] ? 'A' : 'B';
        };

        const code = `${getMode(results.System)}.${getMode(results.Environment)}.${getMode(results.Acquisition)}.${getMode(results.Motivation)}`;
        
        if (!isCalibrating) {
            originalCode = code;
            displayResult(code);
        } else {
            if (code === originalCode) {
                alert("CALIBRATION SUCCESSFUL: Engine Designation Verified.");
                displayResult(code);
            } else {
                const consent = confirm(`DIVERGENCE DETECTED.\n\nInitial: ${originalCode}\nCalibration: ${code}\n\nReset and re-take Intake?`);
                if (consent) initQuiz();
                else displayResult(code);
            }
        }
    }

    function displayResult(code) {
        const p = database[code];
        const mbti = document.getElementById('mbti-select').value;
        const lens = mbtiLenses[mbti];

        document.getElementById('unified-title').innerText = `Unified Strategy: ${p.name} + ${mbti}`;
        document.getElementById('out-code').innerText = `DESIGNATION: ${code}`;
        document.getElementById('out-name').innerText = p.name;
        document.getElementById('out-mantra').innerText = `"${p.mantra}"`;
        document.getElementById('out-desc').innerText = p.desc;
        
        // MIXED ADVICE
        document.getElementById('out-advice').innerText = lens.advice;
        document.getElementById('out-action').innerText = lens.action;
        
        document.getElementById('out-eff').innerText = p.eff;
        document.getElementById('out-fic').innerText = p.fic;
        document.getElementById('out-real').innerText = p.real;

        document.getElementById('quiz').classList.remove('active');
        document.getElementById('results').classList.add('active');
        document.getElementById('progress-fill').style.width = `100%`;
        window.scrollTo(0, 0);
    }
</script>

