<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Activation Matrix | Unified Field Edition</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #141416;           /* Soft Obsidian Base */
            --card: rgba(28, 28, 30, 0.6); 
            --neon: #d4af37;         /* Metallic Gold/Bronze */
            --text: #f5f5f0;         /* Warm Paper White */
            --dim: #a1a1aa;          
            --border: rgba(255, 255, 255, 0.08);
            --accent-b: #8da9c4;     
            --accent-a: #c89f9c;     
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }
        
        body { 
            background-color: var(--bg); 
            color: var(--text); 
            overflow-x: hidden;
            min-height: 100vh;
            position: relative;
        }

        /* LIGHTING & TEXTURE */
        body::before {
            content: "";
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(circle at 50% 30%, #252529 0%, #141416 75%);
            z-index: -2;
        }

        body::after {
            content: "";
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            opacity: 0.04;
            z-index: -1;
            pointer-events: none;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        }

        .header { 
            padding: 1.5rem 2rem; 
            border-bottom: 1px solid var(--border); 
            display: flex; justify-content: space-between; align-items: center; 
            position: sticky; top: 0; 
            background: rgba(20, 20, 22, 0.7); 
            z-index: 100; 
            backdrop-filter: blur(15px); 
        }

        .logo { font-weight: 900; letter-spacing: -1px; text-transform: uppercase; font-size: 1.1rem; }
        .logo span { color: var(--neon); }
        .progress-bar-bg { width: 150px; height: 4px; background: rgba(255,255,255,0.1); border-radius: 2px; }
        #progress-fill { width: 0%; height: 100%; background: var(--neon); box-shadow: 0 0 15px var(--neon); transition: 0.3s; }

        .view { display: none; min-height: 80vh; padding: 3rem 1.5rem; max-width: 900px; margin: 0 auto; }
        .view.active { display: block; animation: fadeIn 0.6s cubic-bezier(0.23, 1, 0.32, 1); }

        #intro { text-align: center; padding-top: 5vh; }
        h1.hero { font-size: 4rem; font-weight: 900; text-transform: uppercase; line-height: 1; margin-bottom: 1.5rem; letter-spacing: -2px; }
        .tagline { color: var(--dim); font-size: 1.2rem; margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto; }

        /* MBTI SELECTOR */
        .mbti-intake { margin-bottom: 3rem; }
        .mbti-intake select {
            background: var(--card);
            color: var(--text);
            border: 1px solid var(--border);
            padding: 1rem 2rem;
            border-radius: 8px;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            outline: none;
        }

        .domain-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 1.5rem; margin-top: 4rem;}
        .domain-box, .opt-btn, .res-section { 
            background: var(--card);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border); 
            padding: 2.5rem; 
            border-radius: 16px; 
            position: relative;
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
            transition: all 0.4s ease;
        }

        .domain-box::before { content: ""; position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: var(--neon); border-radius: 16px 0 0 16px; }
        .domain-title { color: var(--neon); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 3px; font-weight: 800; margin-bottom: 0.5rem; }
        .domain-concept { font-size: 1.1rem; font-weight: 700; margin-bottom: 1.5rem; line-height: 1.4; }
        .binary-split { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
        .binary-option h4 { font-size: 0.8rem; text-transform: uppercase; margin-bottom: 0.5rem; }
        .binary-option p { font-size: 0.85rem; color: var(--dim); line-height: 1.5; }

        .domain-tag { color: var(--neon); text-transform: uppercase; font-size: 0.75rem; letter-spacing: 3px; font-weight: 800; margin-bottom: 1rem; }
        .question { font-size: 2.2rem; font-weight: 700; line-height: 1.2; margin-bottom: 3.5rem; }
        .options-grid { display: grid; gap: 1.2rem; }
        .opt-btn { cursor: pointer; text-align: left; font-size: 1.15rem; }
        .opt-btn:hover { border-color: var(--neon); background: rgba(212, 175, 55, 0.05); transform: translateY(-3px); }
        .opt-btn span { color: var(--neon); font-weight: 900; margin-right: 1rem; }

        .res-header { margin-bottom: 3.5rem; border-left: 6px solid var(--neon); padding-left: 2.5rem; }
        .res-code { font-size: 0.95rem; color: var(--neon); letter-spacing: 4px; font-weight: 800; margin-bottom: 0.75rem; }
        .res-name { font-size: 3.8rem; font-weight: 900; text-transform: uppercase; margin-bottom: 1rem; letter-spacing: -2px; }
        .res-mantra { font-size: 1.4rem; font-style: italic; color: var(--dim); margin-bottom: 1.5rem; }
        .res-description { font-size: 1.15rem; line-height: 1.7; color: var(--text); max-width: 800px; border-top: 1px solid var(--border); padding-top: 1.5rem;}
        
        .strategic-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; }
        .directive-box h4 { font-size: 0.75rem; text-transform: uppercase; color: var(--dim); margin-bottom: 0.75rem; }
        .directive-box p { font-weight: 500; font-size: 1.1rem; line-height: 1.6; }
        .trigger-text { color: var(--neon); font-weight: 800; }

        .btn-main { background: var(--neon); color: #141416; border: none; padding: 1.4rem 3.5rem; font-weight: 900; text-transform: uppercase; cursor: pointer; border-radius: 8px; font-size: 1rem; transition: 0.3s; box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3); }
        .btn-main:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(212, 175, 55, 0.4); }
        .btn-restart { background: transparent; border: 1px solid var(--border); color: var(--dim); padding: 1.2rem 2.2rem; cursor: pointer; text-transform: uppercase; font-size: 0.85rem; border-radius: 8px; transition: 0.3s; }
        .btn-restart:hover { border-color: var(--neon); color: var(--neon); }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        
        @media (max-width: 768px) {
            .domain-grid, .binary-split, .strategic-grid { grid-template-columns: 1fr; }
            h1.hero { font-size: 2.8rem; }
            .res-name { font-size: 2.5rem; }
        }
    </style>
</head>
<body>

<div class="header">
    <div class="logo">Activation <span>Matrix</span></div>
